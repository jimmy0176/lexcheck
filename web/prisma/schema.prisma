// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CheckupStatus {
  draft
  submitted
}

enum CheckupAttachmentKind {
  preliminary
  detailed
  /** 法律体检专属：企查查等三方企业背景报告，与尽调报告的 preliminary/detailed 附件桶完全隔离。 */
  thirdParty
}

enum QuickExamJobStatus {
  pending
  running
  success
  failed
}

enum UserRole {
  lawyer
  client
}

enum RegistrationMode {
  open
  invite_only
}

model User {
  id          String   @id @default(cuid())
  /** 主账号标识，新账号必填；未设置密码时仅可用邮箱验证码登录。 */
  email        String?  @unique
  passwordHash String?
  /** 辅助联系方式，短信验证码接入前仍可用于登录（沿用共享临时验证码机制）；新账号非必填。 */
  phone       String?  @unique
  role        UserRole
  isAdmin     Boolean  @default(false)
  name        String?
  companyName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  sessions    Session[]
  checkups    Checkup[]
  createdTemplates    QuestionnaireTemplate[]
  templateAssignments QuestionnaireAssignment[]

  /** 律师本人的大模型档案；生成报告时优先使用。 */
  llmProviderId String?
  llmModel      String?
  llmApiKey     String?
  llmBaseUrl    String?
}

/** 邮箱验证码（登录/注册/换绑邮箱通用），每次生成新码、限时有效、一次性消费。 */
model EmailVerificationCode {
  id         String    @id @default(cuid())
  email      String
  code       String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email, code])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

/** 单例配置行，id 固定为 "singleton"。 */
model AuthSettings {
  id                         String           @id @default("singleton")
  tempCodeEnabled            Boolean          @default(true)
  tempCode                   String?          @default("888888")
  registrationMode           RegistrationMode @default(invite_only)
  inviteCode                 String?
  questionnaireCooldownHours Int              @default(24)
  updatedAt                  DateTime         @updatedAt

  /** 共用 Key（律师本人未配置或调用失败时，第二优先级）。 */
  sharedLlmProviderId String?
  sharedLlmModel      String?
  sharedLlmApiKey     String?
  sharedLlmBaseUrl    String?

  /** 共用备用 Key（前两者均失败时，第三优先级）。 */
  backupLlmProviderId String?
  backupLlmModel      String?
  backupLlmApiKey     String?
  backupLlmBaseUrl    String?

  /** 系统邮箱（SMTP），用于向客户发送报告等系统邮件。 */
  smtpHost     String?
  smtpPort     Int      @default(465)
  smtpSecure   Boolean  @default(true)
  smtpUser     String?
  smtpPass     String?
  smtpFromName String?
}

model Checkup {
  id          String            @id @default(cuid())
  token       String            @unique
  companyName String?
  contactName String?
  contactPhone String?
  status      CheckupStatus     @default(draft)
  answersJson Json              @default("{}")
  savedAt     DateTime          @default(now())
  submittedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  clientId    String?
  client      User?             @relation(fields: [clientId], references: [id], onDelete: SetNull)
  templateId  String?
  template    QuestionnaireTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  attachments CheckupAttachment[]
  workspace   CheckupWorkspace?
  quickExamJobs QuickExamReportJob[]

  @@index([clientId, submittedAt])
  @@index([templateId])
}

model QuickExamReportJob {
  id          String             @id @default(cuid())
  checkupId   String
  checkup     Checkup            @relation(fields: [checkupId], references: [id], onDelete: Cascade)
  status      QuickExamJobStatus @default(pending)
  /** sync_full | async_chunk */
  mode        String             @default("async_chunk")
  progressJson Json              @default("{}")
  reportText  String?
  errorMessage String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([checkupId, createdAt])
}

model CheckupAttachment {
  id           String   @id @default(cuid())
  checkupId    String
  checkup      Checkup  @relation(fields: [checkupId], references: [id], onDelete: Cascade)
  kind         CheckupAttachmentKind @default(detailed)
  fileName     String
  fileExt      String?
  mimeType     String
  sizeBytes    Int
  storagePath  String
  extractedText String?
  extractError String?
  /** LLM 从三方报告原文提取的 {companyInfo, highlights} 缓存；仅 thirdParty 类型使用，避免每次生成报告都重新调用。 */
  parsedSummaryJson Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([checkupId, createdAt])
  @@index([checkupId, kind, createdAt])
}

model CheckupWorkspace {
  id             String              @id @default(cuid())
  checkupId      String              @unique
  checkup        Checkup             @relation(fields: [checkupId], references: [id], onDelete: Cascade)
  projectStatus  String              @default("待处理")
  ownerName      String?
  promptTemplate String?
  reportTemplate String?
  /** 生成体检报告时是否结合已上传的三方报告（企查查等）。 */
  thirdPartyReportEnabled Boolean    @default(false)
  progressJson   Json                @default("{}")
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  sectionDrafts  CheckupSectionDraft[]
  finalReport    CheckupFinalReport?
}

model CheckupSectionDraft {
  id          String          @id @default(cuid())
  workspaceId String
  workspace   CheckupWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sectionKey  String
  sectionName String
  draftText   String
  reviewedText String?
  included    Boolean         @default(true)
  sourceMeta  Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([workspaceId, sectionKey])
  @@index([workspaceId, updatedAt])
}

model CheckupFinalReport {
  id             String          @id @default(cuid())
  workspaceId    String          @unique
  workspace      CheckupWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  reportText     String
  notesText      String?
  generatedAt    DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  /** 非空即代表已定稿（锁定编辑，需先取消定稿才能再次保存/重新生成）。 */
  finalizedAt    DateTime?
  emailSentAt    DateTime?
  emailSentTo    String?
}

/**
 * 法律体检问卷模板（律师端「问卷配置」页面通过 Excel 导入导出管理）。
 * content 存整份 QuestionnaireConfig 结构（章节/题目/选项）；一旦有 Checkup 关联即视为锁定，
 * 不可再编辑或删除，只能导出后修改重新导入为新模板。仅供法律体检使用，与尽调报告无关。
 */
model QuestionnaireTemplate {
  id          String   @id @default(cuid())
  name        String
  note        String?
  content     Json
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  checkups    Checkup[]
  assignments QuestionnaireAssignment[]
}

/** 问卷模板对客户的推送范围；clientId 为空表示面向所有客户公开。 */
model QuestionnaireAssignment {
  id         String   @id @default(cuid())
  templateId String
  template   QuestionnaireTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  clientId   String?
  client     User?    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([templateId, clientId])
}
